---
import Base from "../layouts/Base.astro";
import { SITE, DOWNLOADS } from "../site";

const features = [
  {
    title: "Plain-English tasks",
    body: "Type what you want. The agent reasons with Claude, plans steps, and recovers from errors on its own.",
  },
  {
    title: "Sees the page",
    body: "An accessibility-tree snapshot gives the model structured elements — refs, roles, labels — not pixels.",
  },
  {
    title: "Acts through run_js",
    body: "The LLM's only tool is run_js. It writes JS that calls page.* APIs; it never touches the DOM or Chrome directly.",
  },
  {
    title: "Bring your own key",
    body: "No inference markup. Point at Anthropic, DeepSeek, GLM, or any Anthropic-compatible endpoint.",
  },
  {
    title: "Skill-aware",
    body: "Activate reusable skills with /skill: and attach session files with @[file:…] — composed into the prompt.",
  },
  {
    title: "Inspectable by design",
    body: "Every step is traced: the generated JS, the result, the error. Nothing happens in a black box.",
  },
];

const steps = [
  {
    n: "01",
    title: "You describe the task",
    body: "“Find the cheapest direct flight from SFO to JFK next Friday and fill the search form.”",
  },
  {
    n: "02",
    title: "The agent reasons + generates JS",
    body: "It snapshots the page, plans, and emits JavaScript via its run_js tool — no direct browser access.",
  },
  {
    n: "03",
    title: "The runtime executes page.* commands",
    body: "@pi-oxide/extension-js runs the JS and dispatches typed BrowserCommands to the active tab.",
  },
  {
    n: "04",
    title: "It observes + iterates",
    body: "The result feeds back to the model. It adjusts, retries on error, and stops when the task is done.",
  },
];
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Experimental · v{SITE.latestVersion}</p>
      <h1>{SITE.tagline}.<br /><span class="muted">An AI agent that lives in your Chrome side panel.</span></h1>
      <p class="lead">{SITE.description}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/download">Download for Chrome →</a>
        <a class="btn btn-secondary" href={SITE.repo}>View on GitHub</a>
      </div>
      <p class="fineprint">
        BYOK · Anthropic-compatible · Chrome MV3 · MIT / Apache-2.0
      </p>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">How it works</p>
      <h2>LLM reasons. JavaScript acts.</h2>
      <p class="lead">The model never touches the DOM or Chrome APIs. It writes JavaScript; a sandboxed runtime turns that into typed page.* commands against the active tab.</p>
      <div class="grid grid-2" style="margin-top:2.5rem">
        {steps.map((s) => (
          <div class="card step">
            <span class="step-n">{s.n}</span>
            <h3>{s.title}</h3>
            <p class="muted">{s.body}</p>
          </div>
        ))}
      </div>
      <pre class="arch" data-lang="architecture"><code>{`Side Panel (Chat UI)
  │  postMessage
  ▼
Web Worker
  ├─ pi-host-web WASM   (state machine, context projection)
  ├─ LLM call           (reasoning — Anthropic Messages API)
  │     └─ only tool: run_js → generates JS
  │           │
  │           ▼
  └─ relayExtjsExecution(code)
        │
        ▼
@pi-oxide/extension-js  →  chrome.tabs.* / content script
        │
        ▼
Active http(s) tab  (snapshot · click · fill · scroll · observe)`}</code></pre>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">What it does</p>
      <h2>Built for transparent browser automation.</h2>
      <div class="grid grid-3" style="margin-top:2.5rem">
        {features.map((f) => (
          <div class="card">
            <h3>{f.title}</h3>
            <p class="muted">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick start -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Quick start</p>
      <h2>Run it from source in a minute.</h2>
      <pre><code>{`git clone ${SITE.repo}.git
cd Browsergent
npm install
npm run build`}</code></pre>
      <p class="muted">Then open <code>chrome://extensions</code>, enable <strong>Developer mode</strong>, and <strong>Load unpacked</strong> the <code>dist/</code> directory. Or grab the prebuilt release on the <a href="/download">download page</a>.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-band">
    <div class="container center">
      <h2>Try Browsergent.</h2>
      <p class="lead center">Experimental v{SITE.latestVersion}. Bring your own API key — no signup, no inference markup.</p>
      <div class="cta-row center">
        <a class="btn btn-primary" href="/download">Get the extension</a>
        <a class="btn btn-secondary" href="/docs">Read the docs</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
  }
  .hero .container { display: flex; flex-direction: column; align-items: center; }
  .hero h1 { max-width: 18ch; margin-bottom: 1.25rem; }
  .hero .muted { color: var(--fg-muted); }
  .hero .lead { text-align: center; max-width: 62ch; }
  .cta-row {
    display: flex;
    gap: 0.85rem;
    justify-content: center;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }
  .cta-row.center { justify-content: center; }
  .fineprint {
    margin-top: 1.25rem;
    color: var(--fg-subtle);
    font-size: 0.85rem;
  }
  .muted { color: var(--fg-muted); }
  .lead.center { margin-left: auto; margin-right: auto; text-align: center; }
  .center { text-align: center; }
  .center .container { display: flex; flex-direction: column; align-items: center; }

  .step { position: relative; padding-left: 3.25rem; }
  .step-n {
    position: absolute;
    top: 1.35rem;
    left: 1.5rem;
    font-family: "SF Mono", Menlo, monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
  }
  .arch { margin-top: 2rem; font-size: 0.82rem; line-height: 1.5; }

  .cta-band { background: var(--bg-subtle); }
</style>
