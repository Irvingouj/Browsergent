---
import Base from "../layouts/Base.astro";
import { SITE } from "../site";

const steps = [
  { n: "01", label: "You describe the task" },
  { n: "02", label: "Agent generates JS" },
  { n: "03", label: "Runtime runs page.*" },
  { n: "04", label: "Observes & iterates" },
];

const features = [
  "Plain-English tasks",
  "Sees the page",
  "Acts via run_js",
  "Bring your own key",
  "Skill-aware",
  "Fully traceable",
];
---

<Base>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Experimental · v{SITE.latestVersion}</p>
      <h1>Claude Code for the browser.</h1>
      <p class="sub">An AI agent that lives in your side panel.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/download">Download for Chrome →</a>
        <a class="btn btn-secondary" href={SITE.repo}>View on GitHub</a>
      </div>
      <p class="fineprint">BYOK · Anthropic-compatible · Chrome MV3</p>

      <figure class="demo">
        <video
          src="/demo.mp4"
          poster="/demo-poster.jpg"
          controls
          muted
          loop
          playsinline
          preload="metadata"
        ></video>
        <figcaption>30-second demo — type a task, watch it work.</figcaption>
      </figure>
    </div>
  </section>

  <section class="band">
    <div class="container split">
      <div class="col">
        <h2>LLM reasons.<br />JavaScript acts.</h2>
        <ol class="steps">
          {steps.map((s) => (
            <li><span class="n">{s.n}</span> {s.label}</li>
          ))}
        </ol>
      </div>
      <div class="col">
        <h2>What it does.</h2>
        <ul class="chips">
          {features.map((f) => (<li>{f}</li>))}
        </ul>
      </div>
    </div>
  </section>

  <section class="quick">
    <div class="container">
      <pre><code>{`git clone ${SITE.repo}.git
cd Browsergent && npm install && npm run build`}</code></pre>
      <p class="hint">Then load <code>dist/</code> in <code>chrome://extensions</code> with Developer mode on.</p>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>Try Browsergent.</h2>
      <div class="cta-row">
        <a class="btn btn-primary" href="/download">Get the extension</a>
        <a class="btn btn-secondary" href="/docs">Read the docs</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 4.5rem 0 2.5rem;
    text-align: center;
  }
  .hero .container { display: flex; flex-direction: column; align-items: center; }
  .hero h1 { max-width: 16ch; margin-bottom: 0.5rem; }
  .sub { font-size: 1.15rem; color: var(--fg-muted); margin-bottom: 1.5rem; }
  .cta-row {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .fineprint {
    margin-top: 1rem;
    color: var(--fg-subtle);
    font-size: 0.82rem;
  }

  .demo { margin: 2.25rem 0 0; width: 100%; max-width: 880px; }
  .demo video {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    background: #000;
    display: block;
  }
  .demo figcaption {
    margin-top: 0.55rem;
    font-size: 0.82rem;
    color: var(--fg-subtle);
  }

  .band { padding: 3rem 0; border-top: 1px solid var(--border); }
  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  @media (max-width: 720px) { .split { grid-template-columns: 1fr; gap: 2rem; } }
  .band h2 { font-size: 1.35rem; margin-bottom: 1rem; }
  .steps { list-style: none; padding: 0; margin: 0; }
  .steps li {
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--fg);
    font-size: 0.98rem;
  }
  .steps li:last-child { border-bottom: none; }
  .steps .n {
    font-family: "SF Mono", Menlo, monospace;
    color: var(--accent);
    font-weight: 700;
    margin-right: 0.75rem;
    font-size: 0.85rem;
  }
  .chips { list-style: none; padding: 0; margin: 0; }
  .chips li {
    display: inline-block;
    margin: 0 0.4rem 0.5rem 0;
    padding: 0.4rem 0.85rem;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.9rem;
    color: var(--fg);
  }

  .quick { padding: 2.5rem 0; border-top: 1px solid var(--border); }
  .quick pre { margin: 0 0 0.75rem; }
  .hint { color: var(--fg-muted); font-size: 0.9rem; margin: 0; }

  .cta {
    padding: 3.5rem 0;
    text-align: center;
    background: var(--bg-subtle);
    border-top: 1px solid var(--border);
  }
  .cta h2 { margin-bottom: 1.25rem; }
</style>
